{
  "name": "weekly_synthesis",
  "description": "Friday 5pm: weekly-synthesizer rolls up the past 7 days, writes a brief to /me/lab-briefs/, then you review and decide what to do with it.",
  "edges": [
    {
      "id": "e1",
      "source": "synthesize",
      "target": "review_brief",
      "label": null
    },
    {
      "id": "e2",
      "source": "review_brief",
      "target": "end",
      "label": null
    }
  ],
  "is_active": true,
  "mode": "GLOBAL",
  "nodes": [
    {
      "config": {
        "agent_name": "weekly-synthesizer",
        "input_mapping": {
          "trigger_week": {
            "value": "last_7_days",
            "type": "literal"
          }
        }
      },
      "id": "synthesize",
      "label": "Write the brief",
      "position": null,
      "type": "AGENT"
    },
    {
      "config": {
        "input_schema": {
          "type": "object",
          "required": [
            "verdict"
          ],
          "properties": {
            "note": {
              "type": "string"
            },
            "verdict": {
              "enum": [
                "keep",
                "regenerate",
                "pin_a_learning",
                "share_one_insight"
              ],
              "type": "string"
            },
            "share_via": {
              "enum": [
                "none",
                "copy_to_clipboard",
                "save_as_file"
              ],
              "type": "string",
              "default": "none"
            }
          }
        },
        "assignee_pod_member_id": null,
        "assignee_pod_member_id_expression": null,
        "ui_schema": {
          "ui:order": [
            "verdict",
            "share_via",
            "note"
          ]
        }
      },
      "id": "review_brief",
      "label": "Review the brief",
      "position": null,
      "type": "FORM"
    },
    {
      "id": "end",
      "config": {},
      "label": "Done",
      "position": null,
      "type": "END"
    }
  ],
  "start": {
    "config": {
      "schedule_type": "CRON"
    },
    "type": "SCHEDULED"
  },
  "visibility": "POD"
}