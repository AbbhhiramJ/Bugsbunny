{
  "name": "experiment_to_learning",
  "description": "When a result is reported: analyst extracts a candidate learning, human reviews, record_learning persists or strengthens an existing row.",
  "edges": [
    {
      "id": "e1",
      "source": "analyst",
      "target": "review",
      "label": null
    },
    {
      "id": "e2",
      "source": "review",
      "target": "route",
      "label": null
    },
    {
      "id": "e3",
      "source": "route",
      "target": "end",
      "label": "skip (default)"
    },
    {
      "id": "e4",
      "source": "persist_new",
      "target": "end",
      "label": null
    },
    {
      "id": "e5",
      "source": "persist_strengthen",
      "target": "end",
      "label": null
    }
  ],
  "is_active": true,
  "mode": "GLOBAL",
  "nodes": [
    {
      "config": {
        "agent_name": "results-analyst",
        "input_mapping": {
          "outcome": {
            "value": "start.payload.outcome",
            "optional": false,
            "type": "expression"
          },
          "evidence": {
            "value": "start.payload.evidence",
            "optional": true,
            "type": "expression"
          },
          "result_id": {
            "value": "start.metadata.record_id",
            "optional": false,
            "type": "expression"
          },
          "surprises": {
            "value": "start.payload.surprises",
            "optional": true,
            "type": "expression"
          },
          "experiment_id": {
            "value": "start.payload.experiment_id",
            "optional": false,
            "type": "expression"
          }
        }
      },
      "id": "analyst",
      "label": "Extract candidate learning",
      "position": null,
      "type": "AGENT"
    },
    {
      "config": {
        "input_schema": {
          "type": "object",
          "required": [
            "decision"
          ],
          "properties": {
            "reason": {
              "type": "string"
            },
            "insight": {
              "type": "string",
              "default": {
                "type": "expression",
                "value": "analyst.insight"
              }
            },
            "decision": {
              "enum": [
                "accept_as_new",
                "strengthen_existing",
                "skip"
              ],
              "type": "string"
            },
            "applies_to": {
              "type": "string",
              "default": {
                "type": "expression",
                "value": "analyst.applies_to"
              }
            },
            "confidence": {
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "type": "string",
              "default": {
                "type": "expression",
                "value": "analyst.confidence"
              }
            },
            "linked_existing_learning_ids": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": {
                "type": "expression",
                "value": "analyst.linked_existing_learning_ids",
                "optional": true
              }
            }
          }
        },
        "assignee_pod_member_id": null,
        "assignee_pod_member_id_expression": null,
        "ui_schema": {
          "ui:order": [
            "decision",
            "insight",
            "applies_to",
            "confidence",
            "linked_existing_learning_ids",
            "reason"
          ]
        }
      },
      "id": "review",
      "label": "Review the learning",
      "position": null,
      "type": "FORM"
    },
    {
      "config": {
        "rules": [
          {
            "condition": "review.decision == `accept_as_new`",
            "next_node_id": "persist_new"
          },
          {
            "condition": "review.decision == `strengthen_existing`",
            "next_node_id": "persist_strengthen"
          }
        ]
      },
      "id": "route",
      "label": "Skip?",
      "position": null,
      "type": "DECISION"
    },
    {
      "config": {
        "function_name": "record_learning",
        "input_mapping": {
          "action": {
            "value": "created",
            "type": "literal"
          },
          "insight": {
            "value": "review.insight",
            "optional": false,
            "type": "expression"
          },
          "applies_to": {
            "value": "review.applies_to",
            "optional": false,
            "type": "expression"
          },
          "confidence": {
            "value": "review.confidence",
            "optional": false,
            "type": "expression"
          },
          "source_result_id": {
            "value": "start.metadata.record_id",
            "optional": false,
            "type": "expression"
          },
          "linked_existing_learning_ids": {
            "value": "review.linked_existing_learning_ids",
            "optional": true,
            "type": "expression"
          }
        }
      },
      "id": "persist_new",
      "label": "Create new learning",
      "position": null,
      "type": "FUNCTION"
    },
    {
      "config": {
        "function_name": "record_learning",
        "input_mapping": {
          "action": {
            "value": "strengthened",
            "type": "literal"
          },
          "insight": {
            "value": "",
            "type": "literal"
          },
          "applies_to": {
            "value": "",
            "type": "literal"
          },
          "confidence": {
            "value": "medium",
            "type": "literal"
          },
          "source_result_id": {
            "value": "start.metadata.record_id",
            "optional": false,
            "type": "expression"
          },
          "linked_existing_learning_ids": {
            "value": "review.linked_existing_learning_ids",
            "optional": false,
            "type": "expression"
          }
        }
      },
      "id": "persist_strengthen",
      "label": "Strengthen existing learning",
      "position": null,
      "type": "FUNCTION"
    },
    {
      "id": "end",
      "config": {},
      "label": "Done",
      "position": null,
      "type": "END"
    }
  ],
  "start": {
    "config": {
      "table_name": "results",
      "operations": [
        "INSERT"
      ]
    },
    "type": "DATASTORE_EVENT"
  },
  "visibility": "POD"
}